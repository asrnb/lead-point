# Supabase — Project Settings > API. Server-only; no direct client-side queries
# in this app, so no anon/public key is needed.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini — ai.google.dev, free tier, no card required
GEMINI_API_KEY=

# Optional fallback LLM — manual env swap, not automatic failover
GROQ_API_KEY=

# Google Sheets CRM sink — service account JSON, base64-encoded
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=
GOOGLE_SHEETS_SPREADSHEET_ID=

# Cal.com booking embed
NEXT_PUBLIC_CAL_COM_LINK=

# Upstash Redis — free tier, used for rate limiting on /api/chat
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin dashboard — single shared password, demo-only auth
ADMIN_PASSWORD=
